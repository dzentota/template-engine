{
    "name": "dzentota/template-engine",
    "description": "A secure template engine with native PHP syntax and context-aware escaping",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alex Tatulchenkov",
            "email": "webtota@gmail.com"
        }
    ],
    "keywords": [
        "template",
        "template-engine",
        "php",
        "security",
        "escaping",
        "xss-protection"
    ],
    "require": {
        "php": "^8.1",
        "dzentota/template-variable": "dev-main",
        "dzentota/typedvalue": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Dzentota\\TemplateEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dzentota\\TemplateEngine\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf"
    }
} 